<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/viewPortComplaints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            tools:context=".complaint.NewComplaintFragment">

            <!-- Title -->
            <EditText
                android:id="@+id/titleComplaint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin10"
                android:background="@drawable/rectangle_outer_box"
                android:hint="Enter the title"
                android:inputType="text"
                android:maxLength="50"
                android:padding="15dp"
                android:textSize="12sp"
                android:fontFamily="@font/montserrat" />

            <TextView
                android:id="@+id/titleError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please enter title"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginTop="4dp" />

            <!-- Complaint -->
            <EditText
                android:id="@+id/complaintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin10"
                android:background="@drawable/rectangle_outer_box"
                android:hint="Write your complaint message"
                android:inputType="textMultiLine"
                android:maxLength="200"
                android:minHeight="120dp"
                android:padding="15dp"
                android:textSize="12sp"
                android:fontFamily="@font/montserrat" />

            <TextView
                android:id="@+id/complaintError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please enter complaint"
                android:textColor="@color/colorPrimary"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginTop="4dp" />

            <!-- 📎 Attach File Section -->
            <LinearLayout
                android:visibility="gone"
                android:id="@+id/attachFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="@drawable/bg_attach_file"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/uploadsvg"
                    app:tint="@color/black" />

                <TextView
                    android:id="@+id/attachFileText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Attach Image or PDF"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <!-- Selected File Name -->
            <TextView
                android:visibility="gone"
                android:id="@+id/fileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No file selected"
                android:textSize="13sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginTop="6dp" />

            <!-- Submit Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/submitComplaint"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:text="Submit"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="@color/textColor"
                app:cornerRadius="@dimen/margin5"
                app:strokeColor="@color/colorPrimary" />

        </LinearLayout>
    </ScrollView>

</layout>